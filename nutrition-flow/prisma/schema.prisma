generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id
  email         String         @unique
  firstName     String
  lastName      String
  age           Int
  currentWeight Float
  targetWeight  Float?
  height        Float
  activityLevel ActivityLevel?
  goal          Goal?
  dietaryType   DietaryType[]  @default([])
  allergies     Allergy[]      @default([])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  meals         Meal[]
  recipes       Recipe[]
}

model Meal {
  id        String   @id @default(uuid())
  name      String
  imageUrl  String
  calories  Int?
  protein   Int?
  carbs     Int?
  fats      Int?
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Recipe {
  id                String        @id @default(uuid())
  name              String
  description       String?
  imageUrl          String?
  prepTimeMinutes   Int
  prepSteps         String[]
  difficulty        Difficulty
  estimatedCalories Int?
  estimatedCost     Float?
  userId            String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  dietaryTags       DietaryType[] @default([])
  ingredients       Ingredient[]
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ingredient {
  id        String   @id @default(uuid())
  name      String
  amount    Float
  unit      Unit
  recipeId  String
  createdAt DateTime @default(now())
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum Goal {
  BULK
  CUT
  MAINTAIN
}

enum DietaryType {
  NONE
  VEGAN
  VEGETARIAN
  KETO
  HALAL
  GLUTEN_FREE
  KOSHER
  PESCATARIAN
}

enum Allergy {
  DAIRY
  EGGS
  PEANUTS
  TREE_NUTS
  SHELLFISH
  GLUTEN
  SOY
  OTHER
  MILK
  FISH
  WHEAT
  SESAME
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Unit {
  G
  ML
  L
  OZ
  CUP
  TBSP
  TSP
  COUNT
}
