generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ENUMS
enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum Goal {
  BULK
  CUT
  MAINTAIN
}

enum DietaryType {
  NONE
  VEGAN
  VEGETARIAN
  KETO
  HALAL
  GLUTEN_FREE
  KOSHER
  PESCATARIAN
}

enum Difficulty {
  EASY      // 1-5 steps
  MEDIUM    // 6-10 steps
  HARD      // 11+ steps
}

enum Unit {
  G         // grams
  ML        // milliliters
  L         // liters
  OZ        // ounces
  CUP       // cups
  TBSP      // tablespoons
  TSP       // teaspoons
  COUNT     // individual items
}

// Model

model User {
  id            String    @id 

  email         String    @unique
  firstName     String   
  lastName      String
  
   
  
  age           Int
  currentWeight Float
  targetWeight  Float?
  height        Float

  // Enums 
  activityLevel ActivityLevel? 
  goal          Goal?          
  dietaryType DietaryType[] @default([])  

  allergies     Allergy[] @default([])

  meals         Meal[]
  recipes       Recipe[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}


model Meal {
  id        String   @id @default(uuid())
  
  name      String
  imageUrl  String
  
  calories  Int?
  protein   Int?
  carbs     Int?
  fats      Int?
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

//SCHEMA

model Recipe {
  id                 String         @id @default(uuid())
  name               String
  description        String?
  imageUrl           String?
  
  // Ingredients with amounts and units
  ingredients        Ingredient[]
  
  // Preparation details
  prepTimeMinutes    Int            // preparation time in minutes
  prepSteps          String[]       // ordered list of preparation steps
  
  // Nutritional and cost info
  difficulty         Difficulty
  estimatedCalories  Int?           // total calories for the recipe
  estimatedCost      Float?         // cost estimation in currency units
  
  // Relationships
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model Ingredient {
  id         String   @id @default(uuid())
  name       String
  amount     Float
  unit       Unit
  
  recipeId   String
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now())
}

